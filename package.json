{
  "name": "ideapilot",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev --config wrangler.api.toml",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "deploy:api": "wrangler deploy --config wrangler.api.toml",
    "deploy:web": "wrangler pages deploy dist --project-name=ideapilot-web",
    "deploy:staging": "wrangler pages deploy dist --project-name=ideapilot-web --branch=staging && wrangler deploy --config wrangler.api.toml --env staging"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.5",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.2",
    "vite": "^6.0.0",
    "wrangler": "^4.103.0"
  }
}
