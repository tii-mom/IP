{
  "name": "ideapilot",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pages": "wrangler pages dev dist --compatibility-date=2024-11-01",
    "build": "vite build",
    "build:full": "vite build && wrangler pages functions build --outdir dist",
    "lint": "tsc --noEmit",
    "start": "wrangler pages dev dist --compatibility-date=2024-11-01",
    "deploy": "npm run build && wrangler pages deploy dist",
    "db:init": "wrangler d1 execute ideapilot --remote --file=./db/schema.sql",
    "db:init:local": "wrangler d1 execute ideapilot --local --file=./db/schema.sql"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.5",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.2",
    "vite": "^6.0.0",
    "wrangler": "^4.103.0"
  }
}
